---
import BaseLayout from '@layouts/BaseLayout.astro';


// Schema de LocalBusiness para ranqueamento do Google localmente em São Francisco do Conde - BA
const structureSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Duarte JR Engenharia e Construções",
  "description": "Soluções completas em engenharia civil, projetos estruturais, execução e gerenciamento de obras em São Francisco do Conde - BA.",
  "image": "https://duartejrengenharia.com.br/logo-duartejr.svg",
  "telephone": "+55-71-99999-9999",
  "email": "contato@duartejrengenharia.com.br",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Centro",
    "addressLocality": "São Francisco do Conde",
    "addressRegion": "BA",
    "postalCode": "43900-000",
    "addressCountry": "BR"
  },
  "url": "https://duartejrengenharia.com.br"
});
---

<BaseLayout 
  title="Duarte JR Engenharia e Construções | Construindo o Amanhã"
  description="Líder em projetos, execução de obras, consultoria e gerenciamento de engenharia civil em São Francisco do Conde - BA. Solicite seu orçamento."
  jsonSchema={structureSchema}
>
  <section id="home" class="section-dark hero-block" aria-labelledby="hero-title">
    <!-- Imagem de Fundo/Lado Direito transbordando a tela -->
    <div class="hero-image-fullscreen-right">
      <img src="/images/hero_background.png" alt="Render de casa moderna de alto padrão por Duarte JR" class="hero-render-img-full animate-hero-bg" />
      <div class="hero-image-overlay-grad"></div>
      <div class="hex-watermark">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" fill="none" stroke="rgba(0, 188, 255, 0.15)" stroke-width="3">
          <polygon points="50 3 93.3 28 93.3 72 50 97 6.7 72 6.7 28"></polygon>
        </svg>
      </div>
    </div>

    <div class="hero-container-custom">
      <div class="hero-text-side">

        <!-- Badge de localização -->
        <div class="hero-badge animate-hero-item delay-hero-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
          <span>São Francisco do Conde &mdash; BA</span>
        </div>

        <!-- Headline principal -->
        <h1 id="hero-title" class="animate-hero-item delay-hero-2">
          Engenharia
          <span class="hero-title-accent">que constrói</span>
          <em class="hero-title-highlight">o amanhã.</em>
        </h1>

        <!-- Linha decorativa -->
        <div class="hero-divider animate-hero-item delay-hero-3">
          <span class="hero-divider-line"></span>
          <span class="hero-divider-dot"></span>
        </div>

        <p class="hero-paragraph animate-hero-item delay-hero-3">
          Soluções completas em engenharia civil — projetos, execução e gerenciamento de obras com qualidade, segurança e compromisso em cada etapa.
        </p>

        <!-- Indicadores de credibilidade -->
        <div class="hero-stats animate-hero-item delay-hero-4">
          <div class="hero-stat-item">
            <strong>+10</strong>
            <span>anos de experiência</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat-item">
            <strong>+80</strong>
            <span>obras entregues</span>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat-item">
            <strong>100%</strong>
            <span>satisfação garantida</span>
          </div>
        </div>

        <div class="hero-btns-wrapper animate-hero-item delay-hero-5">
          <a href="#contato" class="btn btn-primary" id="hero-cta-btn">
            <span>Solicite um Orçamento</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </a>

          <a href="#servicos" class="hero-link-secondary">
            <span class="btn-play-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
            </span>
            <span>Nossos Serviços</span>
          </a>
        </div>

      </div>
    </div>

    <!-- Barra Flutuante de Diferenciais -->
    <div class="hero-floating-specs">
      <div class="specs-wrapper">
        <div class="spec-item">
          <div class="spec-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
          </div>
          <div class="spec-info">
            <h4>Atendimento em</h4>
            <p>São Francisco do Conde - BA</p>
          </div>
        </div>

        <div class="spec-item">
          <div class="spec-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <div class="spec-info">
            <h4>Qualidade e</h4>
            <p>Segurança em cada etapa</p>
          </div>
        </div>

        <div class="spec-item">
          <div class="spec-icon-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <div class="spec-info">
            <h4>Equipe Técnica</h4>
            <p>Especializada e comprometida</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Serviços Section (#servicos - Clara) -->
  <section id="servicos" class="section-light">
    <div class="container">
      <div class="section-header-split reveal">
        <div class="section-header-left">
          <span class="section-tag-light">Nossos Serviços</span>
          <h2>Soluções completas para <span>sua obra.</span></h2>
        </div>
        <div class="section-header-right">
          <p>
            Atuamos em todas as etapas do seu projeto, garantindo eficiência, qualidade e cumprimento de prazos combinados.
          </p>
        </div>
      </div>

      <!-- Grid de Serviços -->
      <div class="services-columns">
        <div class="service-col-card card-glass reveal">
          <div class="service-icon-wrapper">
            <!-- Icone Projetos -->
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line><line x1="15" y1="3" x2="15" y2="21"></line><line x1="3" y1="9" x2="21" y2="9"></line><line x1="3" y1="15" x2="21" y2="15"></line></svg>
          </div>
          <h3>Projetos</h3>
          <p>Desenvolvimento de projetos arquitetônicos, estruturais e complementares sob medida.</p>
        </div>

        <div class="service-col-card card-glass reveal reveal-delay-1">
          <div class="service-icon-wrapper">
            <!-- Icone Execução -->
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path></svg>
          </div>
          <h3>Execução de Obras</h3>
          <p>Construímos com qualidade superior, gerenciando cada etapa com responsabilidade técnica.</p>
        </div>

        <div class="service-col-card card-glass reveal reveal-delay-2">
          <div class="service-icon-wrapper">
            <!-- Icone Consultoria -->
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
          </div>
          <h3>Consultoria</h3>
          <p>Análises técnicas e soluções inteligentes para garantir o sucesso do seu empreendimento.</p>
        </div>

        <div class="service-col-card card-glass reveal reveal-delay-3">
          <div class="service-icon-wrapper">
            <!-- Icone Gerenciamento -->
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          </div>
          <h3>Gerenciamento</h3>
          <p>Gestão completa da sua obra, com controle preciso de prazos, custos e padrões de qualidade.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Por Que Escolher a Duarte JR? Section (#sobre - Escura) -->
  <section id="sobre" class="section-dark why-choose-block">
    <div class="container">
      <div class="why-choose-layout">
        <!-- Coluna Esquerda Institucional -->
        <div class="why-choose-text-side reveal">
          <span class="section-tag-dark">Por que escolher a Duarte JR?</span>
          <h2>Compromisso que gera confiança.</h2>
          <p>
            Mais do que construir estruturas físicas, entregamos tranquilidade e confiança técnica em cada projeto, assegurando durabilidade e excelência nos materiais.
          </p>
          <div style="margin-top: 2.5rem;">
            <a href="#contato" class="btn btn-primary">
              <span>Saiba Mais Sobre Nós</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>

        <!-- Grid da Direita com 4 Diferenciais -->
        <div class="why-choose-grid-side">
          <div class="why-card card-glass reveal">
            <div class="why-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><circle cx="12" cy="12" r="6"></circle><circle cx="12" cy="12" r="2"></circle></svg>
            </div>
            <h4>Foco em Resultados</h4>
            <p>Entregamos soluções eficientes e sob medida para a necessidade de cada cliente.</p>
          </div>

          <div class="why-card card-glass reveal reveal-delay-1">
            <div class="why-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
            </div>
            <h4>Qualidade Garantida</h4>
            <p>Utilização de materiais de alta linha e processos estruturais rigorosos.</p>
          </div>

          <div class="why-card card-glass reveal reveal-delay-2">
            <div class="why-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            </div>
            <h4>Atendimento Próximo</h4>
            <p>Acompanhamento transparente e personalizado da fundação aos acabamentos.</p>
          </div>

          <div class="why-card card-glass reveal reveal-delay-3">
            <div class="why-icon-box">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
            </div>
            <h4>Prazos Respeitados</h4>
            <p>Planejamento e cronograma de obras eficientes para entregar no prazo acordado.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Contato Section (#contato) -->
  <section id="contato" class="section-light">
    <div class="container">
      <!-- Cabeçalho da seção -->
      <div class="contact-header reveal">
        <span class="section-tag-light">Orçamento</span>
        <h2>Conte-nos sobre seu projeto</h2>
        <p class="contact-subtitle">
          Preencha o formulário abaixo com os detalhes do que você precisa. Nossa equipe técnica retorna em até 24 horas úteis com uma proposta personalizada.
        </p>
      </div>

      <div class="contact-columns">
        <!-- Formulário principal -->
        <div class="contact-form-area reveal reveal-delay-1">
          <form id="landing-contact-form">
            <!-- Honeypot anti-spam — campo invisível para bots -->
            <div aria-hidden="true" style="position: absolute; left: -9999px; top: -9999px; overflow: hidden;">
              <label for="website">Não preencha este campo</label>
              <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label">Nome completo</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="Ex: João Silva" required />
              </div>
              <div class="form-group">
                <label for="phone" class="form-label">Telefone / WhatsApp</label>
                <input type="tel" id="phone" name="phone" class="form-input" placeholder="(71) 99999-9999" required />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="email" class="form-label">E-mail</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="seu@email.com" required />
              </div>
              <div class="form-group">
                <label for="service-type" class="form-label">Tipo de serviço</label>
                <select id="service-type" name="service-type" class="form-input" required>
                  <option value="" disabled selected>Selecione uma opção</option>
                  <option value="projetos">Projetos (Estrutural / Complementar)</option>
                  <option value="execucao">Execução de Obras</option>
                  <option value="consultoria">Consultoria Técnica</option>
                  <option value="gerenciamento">Gerenciamento Completo</option>
                  <option value="outro">Outro</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="message" class="form-label">Descreva brevemente o que precisa</label>
              <textarea id="message" name="message" class="form-input" placeholder="Localização da obra, tipo de construção, metragem estimada..." rows="4" required></textarea>
            </div>

            <div id="form-success" class="form-alert success hidden">
              ✓ Mensagem enviada com sucesso! Nossa equipe entrará em contato em breve.
            </div>
            <div id="form-error" class="form-alert error hidden">
              Não foi possível enviar. Tente novamente ou entre em contato pelo WhatsApp.
            </div>

            <div class="form-footer">
              <button type="submit" id="form-submit-btn" class="btn btn-primary">
                <span>Enviar solicitação</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </button>
              <p class="form-privacy">Seus dados são tratados com sigilo. Não fazemos spam.</p>
            </div>
          </form>
        </div>

        <!-- Sidebar de contato direto -->
        <aside class="contact-aside reveal reveal-delay-2">
          <div class="aside-block">
            <h4>Prefere falar diretamente?</h4>
            <p>Você também pode nos chamar pelo WhatsApp para um atendimento mais ágil.</p>
            <a href="https://wa.me/5571999999999" target="_blank" rel="noopener" class="whatsapp-link">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
              <span>Chamar no WhatsApp</span>
            </a>
          </div>

          <div class="aside-block">
            <h4>Onde estamos</h4>
            <ul class="aside-details">
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                <span>São Francisco do Conde — BA</span>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                <span>(71) 99999-9999</span>
              </li>
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                <span>contato@duartejrengenharia.com.br</span>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────── */
  .hero-block {
    position: relative;
    overflow: hidden;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-image-fullscreen-right {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-render-img-full {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-image-overlay-grad {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        #0e0e0e 0%,
        #0e0e0e 15%,
        rgba(14,14,14,0.88) 32%,
        rgba(14,14,14,0.45) 58%,
        rgba(14,14,14,0.05) 100%
      ),
      linear-gradient(to top, #0e0e0e 0%, transparent 18%);
  }

  /* hexágono decorativo sutil */
  .hex-watermark {
    display: none;
  }

  .hero-container-custom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2.5rem;
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    align-items: center;
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 10rem;
  }

  .hero-text-side {
    display: flex;
    flex-direction: column;
    max-width: 560px;
  }

  /* Badge localização */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--text-secondary);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    width: fit-content;
  }

  .hero-badge svg {
    color: var(--primary);
    flex-shrink: 0;
  }

  /* Headline */
  #hero-title {
    font-family: var(--font-title);
    font-size: clamp(2.6rem, 4.5vw, 4rem);
    line-height: 1.08;
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: 0;
    display: flex;
    flex-direction: column;
  }

  .hero-title-accent {
    font-style: italic;
    color: var(--text-secondary);
    font-size: 0.9em;
  }

  .hero-title-highlight {
    font-style: normal;
    color: var(--text-primary);
  }

  /* Divisor simples */
  .hero-divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.5rem 0 1.25rem;
  }

  .hero-divider-line {
    width: 32px;
    height: 1px;
    background: var(--primary);
    opacity: 0.7;
  }

  .hero-divider-dot {
    display: none;
  }

