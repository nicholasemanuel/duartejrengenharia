    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .form-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
  }

  /* Celulares */
  @media (max-width: 600px) {
    #hero-title {
      font-size: 2.2rem;
    }

    .hero-stats {
      flex-wrap: wrap;
      gap: 1rem 1.5rem;
    }

    .hero-stat-divider {
      display: none;
    }

    .why-choose-grid-side {
      grid-template-columns: 1fr;
    }

    .section-header-inline {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.25rem;
    }
  }
</style>

<script>
  // Script para tratar envio do Formulário de Contato com Anti-Spam Invisível e PHP
  const form = document.getElementById('landing-contact-form') as HTMLFormElement;
  const successAlert = document.getElementById('form-success') as HTMLDivElement;
  const errorAlert = document.getElementById('form-error') as HTMLDivElement;
  const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement;
  const btnText = submitBtn.querySelector('span') as HTMLSpanElement;
  const honeypot = document.getElementById('website') as HTMLInputElement;

  // 1. Anti-spam Invisível: Validação Comportamental (Bots não disparam interações reais)
  let isHuman = false;
  const markAsHuman = () => {
    isHuman = true;
    // Remover escutas para economizar recursos
    window.removeEventListener('mousemove', markAsHuman);
    window.removeEventListener('keydown', markAsHuman);
    window.removeEventListener('touchstart', markAsHuman);
  };
  window.addEventListener('mousemove', markAsHuman, { passive: true });
  window.addEventListener('keydown', markAsHuman, { passive: true });
  window.addEventListener('touchstart', markAsHuman, { passive: true });

  // 2. Anti-spam Invisível: Temporizador de carregamento
  const pageLoadTime = Date.now();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // 3. Validar Honeypot
    if (honeypot && honeypot.value) {
      // Simula sucesso para enganar o spammer
      successAlert.textContent = '✓ Solicitação de orçamento enviada com sucesso!';
      successAlert.classList.remove('hidden');
      form.reset();
      return;
    }

    // 4. Validar se é humano e tempo mínimo (humanos levam mais de 3 segundos para ler e preencher)
    const submitTime = Date.now();
    const fillTime = submitTime - pageLoadTime;

    if (!isHuman || fillTime < 3000) {
      // Simula sucesso silencioso para robôs
      successAlert.textContent = '✓ Solicitação de orçamento enviada com sucesso!';
      successAlert.classList.remove('hidden');
      form.reset();
      return;
    }

    // Reset status banners
    successAlert.classList.add('hidden');
    errorAlert.classList.add('hidden');

    // Loading State
    submitBtn.disabled = true;
    btnText.textContent = 'Enviando...';

    const formData = new FormData(form);
    
    // Obter dados para fallback do mailto
    const name = formData.get('name') as string;
    const email = formData.get('email') as string;
    const phone = formData.get('phone') as string;
    const serviceType = formData.get('service-type') as string;
    const message = formData.get('message') as string;

    const serviceLabels: Record<string, string> = {
      arquitetonico: 'Projeto Arquitetônico',
      construcao: 'Construção',
      reformas: 'Reformas',
      acompanhamento: 'Acompanhamento de Obras',
      legalizacao: 'Legalização de Obras',
      laudo: 'Laudo Pericial',
      outro: 'Outro'
    };
    const serviceLabel = serviceLabels[serviceType] || serviceType;

    // Formatação de segurança em texto limpo do e-mail
    const emailBody = `
NOVO CONTATO DE ORÇAMENTO - DUARTE JR
==================================================

DADOS DO CLIENTE
--------------------------------------------------
Nome completo:     ${name}
E-mail:            ${email}
Telefone/WhatsApp: ${phone}
Tipo de serviço:   ${serviceLabel}

MENSAGEM / DETALHES DO PROJETO
--------------------------------------------------
${message}

==================================================
Mensagem enviada do site oficial Duarte JR Engenharia.
Data de envio: ${new Date().toLocaleString('pt-BR')}
`;

    try {
      // Enviar os dados via POST para o arquivo PHP local (rodando na própria Hostinger)
      const response = await fetch('/contato.php', {
        method: 'POST',
        body: formData
      });

      const result = await response.json();

      if (response.ok && result.success) {
        successAlert.textContent = '✓ Solicitação de orçamento enviada com sucesso! Nossa equipe entrará em contato em breve.';
        successAlert.classList.remove('hidden');
        form.reset();
      } else {
        throw new Error(result.message || 'Erro no processamento do PHP');
      }

    } catch (err) {
      // Fallback robusto caso ocorra algum erro ou o servidor local não suporte PHP
      console.warn('Falha no script de email do servidor. Iniciando fallback de e-mail local.', err);
      
      const mailtoUrl = `mailto:contato@duartejrengenharia.com.br?subject=Solicitação de Orçamento - ${encodeURIComponent(name)} (${encodeURIComponent(serviceLabel)})&body=${encodeURIComponent(emailBody)}`;
      window.location.href = mailtoUrl;

      successAlert.textContent = '✓ Redirecionando para seu aplicativo de e-mail padrão para concluir o envio...';
      successAlert.classList.remove('hidden');
      form.reset();

    } finally {
      submitBtn.disabled = false;
      btnText.textContent = 'Enviar solicitação';
    }
  });
</script>
